OPENAI_API_KEY=
PANEL_MODEL_PATH=backend/models/best_panel_detection.pt
BUBBLE_MODEL_PATH=backend/models/best.pt

# --- MLflow ---
# Local file backend, no server needed:
MLFLOW_ENABLED=true
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT=manga_detection
MLFLOW_HTTP_REQUEST_TIMEOUT=5

AWS_REGION=me-central-1
LOG_LEVEL=INFO

# --- CROO Agent SDK (provider integration) ---
# Get your key from the CROO Agent Store (format: croo_sk_...). Never commit it.
CROO_SDK_KEY=
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
# Optional Base RPC endpoint:
# BASE_RPC_URL=https://mainnet.base.org
# Safety switch: leave 0 to run the provider in OBSERVE mode (no on-chain
# accept/deliver). Set to 1 ONLY when you intend to fulfil real paid orders.
CROO_PROVIDER_LIVE=0
